# Shared
ENVIRONMENT=development
PROJECT_NAME="SQL Visual"
LOG_LEVEL=info
JSON_LOGS=true

# Frontend
NEXT_PUBLIC_APP_NAME="SQL Visual"
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000
API_V1_PREFIX=/api/v1

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sqlvisual
POSTGRES_USER=sqlvisual
POSTGRES_PASSWORD=sqlvisual_password
DATABASE_URL=postgresql+asyncpg://sqlvisual:sqlvisual_password@postgres:5432/sqlvisual
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
REDIS_SOCKET_TIMEOUT=5
REDIS_HEALTH_CHECK_INTERVAL=30
REDIS_FAIL_FAST=false

# Observability
REQUEST_TRACE_HEADER=x-request-id
REQUEST_TIMEOUT_SECONDS=60

# AI / LangChain
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0
GROQ_MAX_RETRIES=2
SQL_AGENT_TOP_K=20
SQL_AGENT_MAX_ITERATIONS=12
SQL_AGENT_MAX_EXECUTION_TIME=45
SQL_AGENT_SCHEMA=analytics
SQL_AGENT_INCLUDE_TABLES=order_line_revenue,monthly_sales_summary_view,schema_metadata,sample_queries
SQL_AGENT_SAMPLE_ROWS=3
SQL_AGENT_STREAMING=true
