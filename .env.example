# Shared
ENVIRONMENT=development
PROJECT_NAME="SQL Visual"
LOG_LEVEL=info

# Frontend
NEXT_PUBLIC_APP_NAME="SQL Visual"
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000
API_V1_PREFIX=/api/v1

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sqlvisual
POSTGRES_USER=sqlvisual
POSTGRES_PASSWORD=sqlvisual_password
DATABASE_URL=postgresql+asyncpg://sqlvisual:sqlvisual_password@postgres:5432/sqlvisual

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

